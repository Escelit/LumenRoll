# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=C... # Your deployed contract ID
HOUSE_SECRET_KEY=S... # House Stellar secret key (keep secure!)
TOKEN_CONTRACT_ID=... # Native XLM or custom asset contract ID

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/lumenroll

# Server Configuration
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Security
SECRET_STORE_ENCRYPTION_KEY=your-32-byte-hex-key-here

# Development
NODE_ENV=development
